{
  "name": "claude-code-hook-inspector",
  "version": "0.1.32",
  "description": "CCHI - Monitor and debug Claude Code hooks with an interactive CLI",
  "type": "module",
  "bin": {
    "cchi": "./bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "bin/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "claude-code",
    "hook",
    "inspector",
    "debugger",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
