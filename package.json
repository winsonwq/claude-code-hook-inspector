    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
