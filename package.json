{
  "name": "cchi",
  "version": "0.1.0",
  "description": "CCHI - Monitor and debug Claude Code hooks with an interactive TUI",
  "type": "module",
  "bin": {
    "cchi": "./bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "claude-code",
    "hook",
    "inspector",
    "debugger",
    "tui"
  ],
  "license": "MIT",
  "devDependencies": {
